@* ── LISTADO CITAS ── *@
@model IEnumerable<VET_MVC.Models.mCita>
@{ ViewData["Title"] = "Citas"; Layout = "~/Views/Shared/_Layout.cshtml"; }
<h2>Citas programadas</h2>
<p><a asp-action="agregaCita" class="btn btn-success btn-sm">+ Nueva cita</a></p>
<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr><th>Fecha</th><th>Cliente</th><th>Mascota</th><th>Acciones</th></tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.TF_FecCita.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@item.TC_NombreCliente</td>
                <td>@item.TC_NomMascota</td>
                <td>
                    @Html.ActionLink("Editar",   "modificaCita", new { pId = item.TN_IdCita }, new { @class = "btn btn-warning btn-sm" }) |
                    @Html.ActionLink("Detalle",  "detalleCita",  new { pId = item.TN_IdCita }, new { @class = "btn btn-info btn-sm" }) |
                    @Html.ActionLink("Eliminar", "eliminaCita",  new { pId = item.TN_IdCita }, new { @class = "btn btn-danger btn-sm" })
                </td>
            </tr>
        }
    </tbody>
</table>
