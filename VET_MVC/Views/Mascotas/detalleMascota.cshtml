@* ── DETALLE MASCOTA ── *@
@model VET_MVC.Models.mMascota
@{ ViewData["Title"] = "Detalle mascota"; Layout = "~/Views/Shared/_Layout.cshtml"; }
<h2>Detalle de mascota</h2><hr />
<dl class="row">
    <dt class="col-sm-3">Nombre</dt><dd class="col-sm-9">@Model?.TC_NomMascota</dd>
    <dt class="col-sm-3">Dueño</dt><dd class="col-sm-9">@Model?.TC_NombreCliente</dd>
</dl>
<a asp-action="listadoMascotas" class="btn btn-secondary">Regresar</a>
