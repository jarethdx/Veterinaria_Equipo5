<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Clínica Veterinaria</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-primary mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Clientes" asp-action="listadoClientes">
                    🐾 Veterinaria
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Clientes"
                               asp-action="listadoClientes">Clientes</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Mascotas"
                               asp-action="listadoMascotas">Mascotas</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Citas"
                               asp-action="listadoCitas">Citas</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Diagnostico"
                               asp-action="listadoDiagnosticos">Diagnósticos</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Login"
                               asp-action="login">Cerrar sesión</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container text-center py-2">
            &copy; 2026 - Gestión Clínica Veterinaria - Equipo #5
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
