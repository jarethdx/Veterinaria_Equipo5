@* ── LISTADO ── *@
@model IEnumerable<VET_MVC.Models.mCliente>
@{ ViewData["Title"] = "Clientes"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<h2>Clientes registrados</h2>
<p><a asp-action="agregaCliente" class="btn btn-success btn-sm">+ Nuevo cliente</a></p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(m => m.TC_Nombre)</th>
            <th>@Html.DisplayNameFor(m => m.TC_Ap1)</th>
            <th>@Html.DisplayNameFor(m => m.TC_Ap2)</th>
            <th>@Html.DisplayNameFor(m => m.TC_NumTelefono)</th>
            <th>@Html.DisplayNameFor(m => m.TC_CorreoElectronico)</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.TC_Nombre</td>
                <td>@item.TC_Ap1</td>
                <td>@item.TC_Ap2</td>
                <td>@item.TC_NumTelefono</td>
                <td>@item.TC_CorreoElectronico</td>
                <td>
                    @Html.ActionLink("Editar",   "modificaCliente", new { pId = item.TN_IdCliente }, new { @class = "btn btn-warning btn-sm" }) |
                    @Html.ActionLink("Detalle",  "detalleCliente",  new { pId = item.TN_IdCliente }, new { @class = "btn btn-info btn-sm" }) |
                    @Html.ActionLink("Eliminar", "eliminaCliente",  new { pId = item.TN_IdCliente }, new { @class = "btn btn-danger btn-sm" })
                </td>
            </tr>
        }
    </tbody>
</table>
