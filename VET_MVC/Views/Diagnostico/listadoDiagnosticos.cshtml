@* ── LISTADO DIAGNÓSTICO ── *@
@model IEnumerable<VET_MVC.Models.mDiagnostico>
@{ ViewData["Title"] = "Diagnósticos"; Layout = "~/Views/Shared/_Layout.cshtml"; }
<h2>Diagnósticos registrados</h2>
<p><a asp-action="agregaDiagnostico" class="btn btn-success btn-sm">+ Nuevo diagnóstico</a></p>
<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr><th>Mascota</th><th>Fecha cita</th><th>Diagnóstico</th><th>Acciones</th></tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.TC_NomMascota</td>
                <td>@item.TF_FecCita?.ToString("dd/MM/yyyy")</td>
                <td>@item.TC_DscDiagnostico</td>
                <td>
                    @Html.ActionLink("Editar",   "modificaDiagnostico", new { pId = item.TN_IdDiagnostico }, new { @class = "btn btn-warning btn-sm" }) |
                    @Html.ActionLink("Detalle",  "detalleDiagnostico",  new { pId = item.TN_IdDiagnostico }, new { @class = "btn btn-info btn-sm" }) |
                    @Html.ActionLink("Eliminar", "eliminaDiagnostico",  new { pId = item.TN_IdDiagnostico }, new { @class = "btn btn-danger btn-sm" })
                </td>
            </tr>
        }
    </tbody>
</table>
